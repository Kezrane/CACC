#This configures Git to ignore compiled binaries, temporary simulation logs, native build artifacts, and system files generated #during ndnSIM execution.

# Prerequisites and system files
*.d
*.o
*.pyc
.DS_Store
.vscode/
.idea/

# ns-3 / ndnSIM Build artifacts
build/
.waf-*
.waf3-*
lock-modules
.lock-waf_*

# Simulation output data and traces
scenarios/*.txt
scenarios/*.log
*.csv
*.tr
*.pcap

# Executables generated by scenarios
scenarios/cacc-geant-scenario
scenarios/cacc-iot-scenario